generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActorRole {
  PATIENT
  DOCTOR
  SYSTEM
}

enum ArtifactKind {
  PROOF
  MESSAGE_ATTACHMENT
}

enum ArtifactStatus {
  STAGED
  READY
  FAILED
  DELETED
}

enum SubmissionStatus {
  DRAFT
  OPEN
  FINALIZED
  EXPIRED
  CANCELLED
}

model Doctor {
  id                String                @id @default(uuid())
  wpUserId          Int?                  @unique // Pont avec le login Hostinger
  firstName         String?
  lastName          String?
  email             String?               @unique
  phone             String?
  twilioPhone       String?               // Numéro public de télé-prescription (Twilio) affichable sur le PDF
  university        String?               // Faculté / université de médecine
  distinctions      String?               // Distinctions / honors du prescripteur
  title             String?
  specialty         String?
  rpps              String?               @unique
  amNumber          String?               // Numéro Assurance Maladie
  address           String?
  city              String?
  zipCode           String?
  signatureS3Key    String?               // Fichier stocké sécurisé sur S3 (Plus d'image WP)
  deletedAt         DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  prescriptions     Prescription[]
  authoredMessages  PrescriptionMessage[] @relation("DoctorAuthoredMessages")
  uploadedArtifacts Artifact[]            @relation("DoctorUploadedArtifacts")

}

model Patient {
  id            String         @id @default(uuid())
  wpUserId      Int?           @unique
  firstName     String
  lastName      String
  birthDate     String
  gender        String?
  email         String?
  phone         String?
  weightKg      String?
  heightCm      String?
  note          String?
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  prescriptions Prescription[]

}

model Prescription {
  id                   String                @id @default(uuid())
  uid                  String                @unique // Référence publique courte (ex: QEZT4VS62H)
  doctorId             String?
  patientId            String
  doctor               Doctor?               @relation(fields: [doctorId], references: [id])
  patient              Patient               @relation(fields: [patientId], references: [id])
  status               String                @default("PENDING") // PENDING, APPROVED, REJECTED
  items                Json                  // Tableau JSONB natif contenant la posologie
  privateNotes         String?
  s3PdfKey             String?               // Lien vers l'artefact généré
  verifyCode           String?
  verifyToken          String?               @unique
  processingStatus     String                @default("PENDING")
  availableAt          DateTime              @default(now())
  claimedAt            DateTime?
  lockExpiresAt        DateTime?
  workerRef            String?
  attempts             Int                   @default(0)
  maxAttempts          Int                   @default(5)
  lastErrorCode        String?
  lastErrorMessageSafe String?
  sourceReqId          String?               @unique
  flowKey              String?
  priority             String                @default("standard")
  hasProof             Boolean               @default(false)
  proofCount           Int                   @default(0)
  messageCount         Int                   @default(0)
  lastMessageSeq       Int                   @default(0)
  lastMessageAt        DateTime?
  lastMessageRole      ActorRole?
  doctorLastReadSeq    Int                   @default(0)
  patientLastReadSeq   Int                   @default(0)
  unreadCountDoctor    Int                   @default(0)
  unreadCountPatient   Int                   @default(0)
  messages             PrescriptionMessage[]
  artifacts            Artifact[]
  paymentActionJobs    PaymentActionJob[]
  finalizedBySubmission Submission?          @relation("SubmissionFinalizedPrescription")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([doctorId])
  @@index([patientId])
  @@index([processingStatus, availableAt, lockExpiresAt, createdAt])
  @@index([workerRef, lockExpiresAt])
  @@index([status, updatedAt])
  @@index([hasProof, status, updatedAt])
  @@index([unreadCountDoctor, status, updatedAt])
  @@index([unreadCountPatient, status, updatedAt])
  @@index([lastMessageAt, updatedAt])
}

model PrescriptionMessage {
  id             String        @id @default(uuid())
  prescriptionId String
  prescription   Prescription  @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  seq            Int
  authorRole     ActorRole
  authorWpUserId Int?
  authorDoctorId String?
  authorDoctor   Doctor?       @relation("DoctorAuthoredMessages", fields: [authorDoctorId], references: [id], onDelete: SetNull)
  body           String
  createdAt      DateTime      @default(now())
  attachments    Artifact[]

  @@unique([prescriptionId, seq])
  @@index([prescriptionId, createdAt])
}

model Submission {
  id                     String           @id @default(uuid())
  publicRef              String           @unique @default(cuid())
  ownerRole              ActorRole
  ownerWpUserId          Int?
  status                 SubmissionStatus @default(OPEN)
  flowKey                String
  priority               String           @default("standard")
  expiresAt              DateTime
  finalizedPrescriptionId String?         @unique
  finalizedPrescription  Prescription?    @relation("SubmissionFinalizedPrescription", fields: [finalizedPrescriptionId], references: [id], onDelete: SetNull)
  artifacts              Artifact[]
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@index([status, expiresAt])
  @@index([ownerRole, ownerWpUserId, status, expiresAt])
  @@index([flowKey, status, createdAt])
  @@index([createdAt])
}

model PaymentActionJob {
  id                   String       @id
  siteId               String
  kind                 String
  prescriptionId       String
  prescription         Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  wpPrescriptionId     Int?
  paymentIntentId      String
  provider             String       @default("stripe")
  status               String       @default("PENDING")
  attempts             Int          @default(0)
  maxAttempts          Int          @default(8)
  availableAt          DateTime     @default(now())
  claimedAt            DateTime?
  lockExpiresAt        DateTime?
  workerRef            String?
  reqId                String?
  payload              Json?
  result               Json?
  lastErrorCode        String?
  lastErrorMessageSafe String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([siteId, kind, prescriptionId, paymentIntentId], map: "PaymentActionJob_unique_action")
  @@index([siteId, status, availableAt, lockExpiresAt], map: "PaymentActionJob_claim_idx")
  @@index([paymentIntentId], map: "PaymentActionJob_intent_idx")
}

model Artifact {
  id                 String               @id @default(uuid())
  prescriptionId     String?
  prescription       Prescription?        @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)
  submissionId       String?
  submission         Submission?          @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  messageId          String?
  message            PrescriptionMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  kind               ArtifactKind
  status             ArtifactStatus       @default(STAGED)
  ownerRole          ActorRole
  ownerWpUserId      Int?
  uploadedByDoctorId String?
  uploadedByDoctor   Doctor?              @relation("DoctorUploadedArtifacts", fields: [uploadedByDoctorId], references: [id], onDelete: SetNull)
  draftKey           String?              @unique
  originalName       String
  mimeType           String
  sizeBytes          Int
  sha256Hex          String?
  s3Bucket           String?
  s3Region           String?
  s3Key              String?
  meta               Json?
  linkedAt           DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  deletedAt          DateTime?

  @@index([prescriptionId, kind, createdAt])
  @@index([submissionId, kind, createdAt])
  @@index([messageId, createdAt])
  @@index([ownerWpUserId, createdAt])
}


model AuthToken {
  id            String    @id @default(uuid())
  token         String    @unique
  email         String
  ownerRole     ActorRole
  ownerWpUserId Int?
  meta          Json?
  expiresAt     DateTime
  used          Boolean   @default(false)

  @@index([email, expiresAt])
  @@index([used, expiresAt])
}


model BdpmMedication {
  cis                         String                    @id
  denomination                String
  normalizedDenomination      String
  pharmaceuticalForm          String
  administrationRoutesRaw     String
  administrativeStatus        String
  authorizationProcedure      String
  commercializationState      String
  authorizationDate           DateTime?
  statusBdm                   String?
  europeanAuthorizationNumber String?
  holdersRaw                  String?
  isUnderAdditionalMonitoring Boolean                   @default(false)
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt
  presentations               BdpmPresentation[]
  compositions                BdpmComposition[]
  genericGroupMembers         BdpmGenericGroupMember[]
  prescriptionConditions      BdpmPrescriptionCondition[]
  availabilityStatuses        BdpmAvailabilityStatus[]
  therapeuticInterests        BdpmTherapeuticInterest[]
  importantInfos              BdpmImportantInfo[]

  @@index([normalizedDenomination])
  @@index([denomination])
  @@index([commercializationState])
  @@index([authorizationDate])
}

model BdpmPresentation {
  id                               String         @id
  cis                              String
  medication                       BdpmMedication @relation(fields: [cis], references: [cis], onDelete: Cascade)
  cip7                             String
  cip13                            String
  label                            String
  normalizedLabel                  String
  presentationStatus               String
  presentationCommercializationState String
  commercializationDeclarationDate DateTime?
  collectivitiesApproval           String?
  reimbursementRate                String?
  priceEuro                        Decimal?       @db.Decimal(10, 2)
  publicPriceEuro                  Decimal?       @db.Decimal(10, 2)
  dispensingFeeEuro                Decimal?       @db.Decimal(10, 2)
  reimbursementIndications         String?
  createdAt                        DateTime       @default(now())
  updatedAt                        DateTime       @updatedAt

  @@unique([cip13])
  @@unique([cis, cip7])
  @@index([cis])
  @@index([cip7])
  @@index([normalizedLabel])
  @@index([presentationCommercializationState])
}

model BdpmComposition {
  id                                 String         @id
  cis                                String
  medication                         BdpmMedication @relation(fields: [cis], references: [cis], onDelete: Cascade)
  pharmaceuticalElementDesignation   String
  substanceCode                      String
  substanceName                      String
  dosage                             String?
  dosageReference                    String?
  componentNature                    String
  componentLinkNumber                String?
  createdAt                          DateTime       @default(now())
  updatedAt                          DateTime       @updatedAt

  @@index([cis])
  @@index([substanceCode])
  @@index([substanceName])
  @@index([componentNature])
}

model BdpmGenericGroupMember {
  id               String         @id
  cis              String
  medication       BdpmMedication @relation(fields: [cis], references: [cis], onDelete: Cascade)
  groupId          String
  groupLabel       String
  genericType      Int
  genericTypeLabel String
  sortOrder        Int
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([cis])
  @@index([groupId, sortOrder])
  @@index([genericType])
}

model BdpmPrescriptionCondition {
  id                  String         @id
  cis                 String
  medication          BdpmMedication @relation(fields: [cis], references: [cis], onDelete: Cascade)
  conditionText       String
  normalizedCondition String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([cis, conditionText])
  @@index([cis])
  @@index([normalizedCondition])
}

model BdpmAvailabilityStatus {
  id               String         @id
  cis              String
  medication       BdpmMedication @relation(fields: [cis], references: [cis], onDelete: Cascade)
  cip13            String?
  statusCode       Int
  statusLabel      String
  startDate        DateTime?
  updatedDate      DateTime?
  resupplyDate     DateTime?
  ansmUrl          String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([cis])
  @@index([cip13])
  @@index([statusCode])
  @@index([updatedDate])
}

model BdpmTherapeuticInterest {
  id              String         @id
  cis             String
  medication      BdpmMedication @relation(fields: [cis], references: [cis], onDelete: Cascade)
  atcCode         String
  denomination    String
  bdpmUrl         String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([cis, atcCode])
  @@index([cis])
  @@index([atcCode])
}

model BdpmImportantInfo {
  id             String         @id
  cis            String
  medication     BdpmMedication @relation(fields: [cis], references: [cis], onDelete: Cascade)
  startDate      DateTime?
  endDate        DateTime?
  messageAndUrl  String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([cis])
  @@index([startDate])
  @@index([endDate])
}
