// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Doctor {
  id             String         @id @default(uuid())
  wpUserId       Int            @unique // Pont avec le login Hostinger
  firstName      String?
  lastName       String?
  email          String?        @unique
  phone          String?
  title          String?
  specialty      String?
  rpps           String?        @unique
  amNumber       String? // Numéro Assurance Maladie
  address        String?
  city           String?
  zipCode        String?
  signatureS3Key String? // Fichier stocké sécurisé sur S3 (Plus d'image WP)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  prescriptions  Prescription[]
}

model Patient {
  id            String         @id @default(uuid())
  firstName     String
  lastName      String
  birthDate     String
  gender        String?
  email         String?
  phone         String?
  weightKg      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  prescriptions Prescription[]
}

model Prescription {
  id                   String    @id @default(uuid())
  uid                  String    @unique // Référence publique courte (ex: QEZT4VS62H)
  doctorId             String?
  patientId            String
  doctor               Doctor?   @relation(fields: [doctorId], references: [id])
  patient              Patient   @relation(fields: [patientId], references: [id])
  status               String    @default("PENDING") // PENDING, APPROVED, REJECTED
  items                Json // Tableau JSONB natif contenant la posologie
  privateNotes         String?
  s3PdfKey             String? // Lien vers l'artefact généré
  verifyCode           String?
  verifyToken          String?   @unique
  processingStatus     String    @default("PENDING")
  availableAt          DateTime  @default(now())
  claimedAt            DateTime?
  lockExpiresAt        DateTime?
  workerRef            String?
  attempts             Int       @default(0)
  maxAttempts          Int       @default(5)
  lastErrorCode        String?
  lastErrorMessageSafe String?
  sourceReqId          String?   @unique
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([doctorId])
  @@index([patientId])
  @@index([processingStatus, availableAt, lockExpiresAt, createdAt])
  @@index([workerRef, lockExpiresAt])
}
